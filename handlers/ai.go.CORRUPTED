type AskRequest struct {
    Question    string `json:"question" binding:"required"`
    CRMContext  bool   `json:"crm_context"`
    Recommend   bool   `json:"recommend"`
    RequestType string `json:"request_type"`
    SessionID   string `json:"session_id"`
}

type ServiceRequest struct {
    ID            string    `json:"id"`
    Name          string    `json:"name"`
    Contact       string    `json:"contact"`
    ContactType   string    `json:"contact_type"`
    Description   string    `json:"description"`
    ServiceType   string    `json:"service_type"`
    Goal          string    `json:"goal"`
    Timeline      string    `json:"timeline"`
    Budget        string    `json:"budget"`
    Status        string    `json:"status"`
    CreatedAt     time.Time `json:"created_at"`
    HasWhatsApp   bool      `json:"has_whatsapp"`
    HasTelegram   bool      `json:"has_telegram"`
    HasMessenger  bool      `json:"has_messenger"`
    TotalAmount   float64   `json:"total_amount"`
    ExtraService  string    `json:"extra_service"`
    ProjectCost   float64   `json:"project_cost"`
    AgreedToPrice bool      `json:"agreed_to_price"`
    AgreedToExtra bool      `json:"agreed_to_extra"`
    Design        string    `json:"design"`
    Features      string    `json:"features"`
    Integration   string    `json:"integration"`
    TargetAudience string   `json:"target_audience"`
    TelegramNick  string    `json:"telegram_nick"`
}

type DialogState struct {
    Step              int       `json:"step"`
    DialogType        string    `json:"dialog_type"`
    UserName          string    `json:"user_name"`
    ServiceType       string    `json:"service_type"`
    Description       string    `json:"description"`
    Goal              string    `json:"goal"`
    Timeline          string    `json:"timeline"`
    Contact           string    `json:"contact"`
    ContactType       string    `json:"contact_type"`
    TelegramNick      string    `json:"telegram_nick"`
    Problem           string    `json:"problem"`
    ProblemDetails    string    `json:"problem_details"`
    Messages          []string  `json:"messages"`
    LastUpdated       time.Time `json:"last_updated"`
    GreetingShown     bool      `json:"greeting_shown"`
    NameAsked         bool      `json:"name_asked"`
    EstimatedCost     float64   `json:"estimated_cost"`
    AgreedToPrice     bool      `json:"agreed_to_price"`
    AskedExtraService bool      `json:"asked_extra_service"`
    AgreedToExtra     bool      `json:"agreed_to_extra"`
    HasWhatsApp       bool      `json:"has_whatsapp"`
    HasTelegram       bool      `json:"has_telegram"`
    HasMessenger      bool      `json:"has_messenger"`
    AskedMessengers   bool      `json:"asked_messengers"`
    ForceRequestSent  bool      `json:"force_request_sent"`
    Design            string    `json:"design"`
    Features          string    `json:"features"`
    Integration       string    `json:"integration"`
    TargetAudience    string    `json:"target_audience"`
    PriceCalculated   bool      `json:"price_calculated"`
    NotificationSent  bool      `json:"notification_sent"`
}

var (
    dialogStates = make(map[string]*DialogState)
    dialogMutex  = &sync.RWMutex{}
)

func init() {
    go startCleanupRoutine()
}

func startCleanupRoutine() {
    defer func() {
        if r := recover(); r != nil {
            log.Printf("[PANIC] В горутине очистки сессий: %v", r)
            time.Sleep(1 * time.Minute)
            go startCleanupRoutine()
        }
    }()

    for {
        time.Sleep(1 * time.Hour)
        cleanupSessions()
    }
}

func cleanupSessions() {
    dialogMutex.Lock()
    defer dialogMutex.Unlock()

    now := time.Now()
    for sessionID, state := range dialogStates {
        if now.Sub(state.LastUpdated) > 24*time.Hour {
            delete(dialogStates, sessionID)
            log.Printf("[INFO] Удалена устаревшая сессия: %s", sessionID)
        }
    }
}

// 🔍 Функция поиска в Яндекс
func searchWithYandex(query string) (string, error) {
    apiKey := os.Getenv("YANDEX_SEARCH_API_KEY")
    folderID := os.Getenv("YANDEX_FOLDER_ID")

    if apiKey == "" || folderID == "" {
        return "", fmt.Errorf("поиск не настроен: отсутствуют API ключи")
    }

    log.Printf("[SEARCH] Запрос: %s", query)

    requestBody := map[string]interface{}{
        "query": map[string]string{
            "text": query,
        },
        "maxResults": 5,
        "type":       "web",
    }

    jsonBody, err := json.Marshal(requestBody)
    if err != nil {
        return "", fmt.Errorf("ошибка формирования запроса: %v", err)
    }

    url := fmt.Sprintf("https://searchapi.api.cloud.yandex.net/v2/web/search?folderId=%s", folderID)

    req, err := http.NewRequest("POST", url, bytes.NewBuffer(jsonBody))
    if err != nil {
        return "", fmt.Errorf("ошибка создания запроса: %v", err)
    }

    req.Header.Set("Content-Type", "application/json")
    req.Header.Set("Authorization", "Api-Key "+apiKey)

    client := &http.Client{Timeout: 15 * time.Second}
    resp, err := client.Do(req)
    if err != nil {
        return "", fmt.Errorf("ошибка выполнения запроса: %v", err)
    }
    defer resp.Body.Close()

    body, err := io.ReadAll(resp.Body)
    if err != nil {
        return "", fmt.Errorf("ошибка чтения ответа: %v", err)
    }

    if resp.StatusCode != http.StatusOK {
        return "", fmt.Errorf("API вернул ошибку %d: %s", resp.StatusCode, string(body))
    }

    var searchResp struct {
        Results []struct {
            Title   string `json:"title"`
            Url     string `json:"url"`
            Snippet struct {
                Text string `json:"text"`
            } `json:"snippet"`
        } `json:"results"`
    }

    if err := json.Unmarshal(body, &searchResp); err != nil {
        log.Printf("[ERROR] Не удалось распарсить ответ: %s", string(body))
        return "", fmt.Errorf("ошибка парсинга ответа: %v", err)
    }

    if len(searchResp.Results) == 0 {
        return "По вашему запросу ничего не найдено.", nil
    }

    var sb strings.Builder
    sb.WriteString("🔍 **Результаты поиска:**\n\n")

    for i, result := range searchResp.Results {
        if i >= 5 {
            break
        }
        sb.WriteString(fmt.Sprintf("**%d. %s**\n", i+1, result.Title))
        if result.Snippet.Text != "" {
            snippet := result.Snippet.Text
            if len(snippet) > 200 {
                snippet = snippet[:200] + "..."
            }
            sb.WriteString(fmt.Sprintf("   %s\n", snippet))
        }
        sb.WriteString(fmt.Sprintf("   [Источник](%s)\n\n", result.Url))
    }

    log.Printf("[SEARCH] Найдено результатов: %d", len(searchResp.Results))
    return sb.String(), nil
}

// 💰 Функция поиска цен с контекстом
func searchAverageBotPrice(query string, serviceType string) (string, float64, error) {
    log.Printf("[PRICE] Поиск цен: %s (контекст: %s)", query, serviceType)

    projectType := "Telegram бота"
    if strings.Contains(strings.ToLower(serviceType), "crm") {
        projectType = "CRM системы"
    } else if strings.Contains(strings.ToLower(serviceType), "сайт") || 
               strings.Contains(strings.ToLower(serviceType), "магазин") {
        projectType = "интернет магазина"
    } else if strings.Contains(strings.ToLower(serviceType), "бот") {
        projectType = "Telegram бота"
    }

    // Формируем поисковый запрос для Яндекса
    searchQuery := fmt.Sprintf("сколько стоит разработка %s цена 2026 средний чек", projectType)
    
    apiKey := os.Getenv("YANDEX_SEARCH_API_KEY")
    folderID := os.Getenv("YANDEX_FOLDER_ID")

    if apiKey == "" || folderID == "" {
        log.Printf("[WARN] Поиск цен не настроен, возвращаем стандартные цены")
        return getDefaultPriceInfo(projectType), 45000, nil
    }

    // Запрос к Yandex Search API
    requestBody := map[string]interface{}{
        "query": map[string]string{
            "text": searchQuery,
        },
        "maxResults": 10,
        "type":       "web",
    }

    jsonBody, err := json.Marshal(requestBody)
    if err != nil {
        log.Printf("[ERROR] Ошибка формирования запроса: %v", err)
        return getDefaultPriceInfo(projectType), 45000, nil
    }

    url := fmt.Sprintf("https://searchapi.api.cloud.yandex.net/v2/web/search?folderId=%s", folderID)

    req, err := http.NewRequest("POST", url, bytes.NewBuffer(jsonBody))
    if err != nil {
        log.Printf("[ERROR] Ошибка создания запроса: %v", err)
        return getDefaultPriceInfo(projectType), 45000, nil
    }

    req.Header.Set("Content-Type", "application/json")
    req.Header.Set("Authorization", "Api-Key "+apiKey)

    client := &http.Client{Timeout: 10 * time.Second}
    resp, err := client.Do(req)
    if err != nil {
        log.Printf("[ERROR] Ошибка выполнения запроса: %v", err)
        return getDefaultPriceInfo(projectType), 45000, nil
    }
    defer resp.Body.Close()

    body, err := io.ReadAll(resp.Body)
    if err != nil {
        log.Printf("[ERROR] Ошибка чтения ответа: %v", err)
        return getDefaultPriceInfo(projectType), 45000, nil
    }

    if resp.StatusCode != http.StatusOK {
        log.Printf("[ERROR] API вернул ошибку %d: %s", resp.StatusCode, string(body))
        return getDefaultPriceInfo(projectType), 45000, nil
    }

    var searchResp struct {
        Results []struct {
            Title   string `json:"title"`
            Url     string `json:"url"`
            Snippet struct {
                Text string `json:"text"`
            } `json:"snippet"`
        } `json:"results"`
    }

    if err := json.Unmarshal(body, &searchResp); err != nil {
        log.Printf("[ERROR] Ошибка парсинга ответа: %v", err)
        return getDefaultPriceInfo(projectType), 45000, nil
    }

    // Анализируем результаты поиска и извлекаем цены
    var prices []float64
    re := regexp.MustCompile(`(\d{1,3}(?:[.\s]?\d{3})*)\s*(?:тыс\.?|тысяч|₽|руб|рублей|р\.)`)
    
    for _, result := range searchResp.Results {
        text := result.Title + " " + result.Snippet.Text
        text = strings.ToLower(text)
        
        matches := re.FindAllStringSubmatch(text, -1)
        for _, match := range matches {
            if len(match) > 1 {
                // Очищаем число от пробелов и точек
                priceStr := strings.ReplaceAll(match[1], " ", "")
                priceStr = strings.ReplaceAll(priceStr, ".", "")
                
                price, err := strconv.ParseFloat(priceStr, 64)
                if err != nil {
                    continue
                }
                
                // Если цена в тысячах
                if strings.Contains(match[0], "тыс") || strings.Contains(match[0], "тысяч") {
                    price *= 1000
                }
                
                // Фильтруем реалистичные цены (от 10 000 до 500 000)
                if price > 10000 && price < 500000 {
                    prices = append(prices, price)
                }
            }
        }
    }

    // Если нашли цены в интернете, используем их
    if len(prices) > 0 {
        sum := 0.0
        minPrice := 1000000.0
        maxPrice := 0.0
        
        for _, p := range prices {
            sum += p
            if p < minPrice {
                minPrice = p
            }
            if p > maxPrice {
                maxPrice = p
            }
        }
        
        avgPrice := sum / float64(len(prices))
        
        // Округляем до тысяч
        avgPrice = float64(int(avgPrice/1000)) * 1000
        
        var sb strings.Builder
        sb.WriteString(fmt.Sprintf("💰 **Анализ цен на %s (данные из интернета):**\n\n", projectType))
        sb.WriteString(fmt.Sprintf("📊 Средняя цена: **%.0f ₽**\n", avgPrice))
        sb.WriteString(fmt.Sprintf("📈 Минимальная: **%.0f ₽**\n", minPrice))
        sb.WriteString(fmt.Sprintf("📉 Максимальная: **%.0f ₽**\n", maxPrice))
        sb.WriteString(fmt.Sprintf("🔍 На основе %d источников\n\n", len(prices)))
        sb.WriteString("💡 **Рекомендуемая стоимость вашего проекта:**\n")
        sb.WriteString(fmt.Sprintf("• Базовая комплектация: **%.0f ₽**\n", avgPrice*0.8))
        sb.WriteString(fmt.Sprintf("• Оптимальная: **%.0f ₽**\n", avgPrice))
        sb.WriteString(fmt.Sprintf("• С расширенным функционалом: **%.0f ₽**\n", avgPrice*1.2))
        
        log.Printf("[PRICE] Найдено цен: %d, средняя: %.0f", len(prices), avgPrice)
        return sb.String(), avgPrice, nil
    }

    // Если ничего не нашли, возвращаем стандартные цены
    log.Printf("[PRICE] Цены не найдены, возвращаем стандартные")
    return getDefaultPriceInfo(projectType), 45000, nil
}

// Вспомогательная функция для стандартных цен
func getDefaultPriceInfo(projectType string) string {
    var sb strings.Builder
    sb.WriteString(fmt.Sprintf("💰 **Средние цены на %s:**\n\n", projectType))
    
    switch {
    case strings.Contains(projectType, "CRM"):
        sb.WriteString("• Простая CRM: 30 000 - 50 000 ₽\n")
        sb.WriteString("• CRM с интеграциями: 50 000 - 80 000 ₽\n")
        sb.WriteString("• Сложная CRM: 80 000 - 150 000 ₽\n")
    case strings.Contains(projectType, "магазин"):
        sb.WriteString("• Простой магазин: 40 000 - 70 000 ₽\n")
        sb.WriteString("• Магазин с платежами: 70 000 - 120 000 ₽\n")
        sb.WriteString("• Маркетплейс: 120 000 - 200 000 ₽\n")
    default: // боты
        sb.WriteString("• Простой бот (уведомления): 20 000 - 35 000 ₽\n")
        sb.WriteString("• Средний бот (рассылки + админка): 35 000 - 60 000 ₽\n")
        sb.WriteString("• Сложный бот (платежи + CRM): 60 000 - 100 000 ₽\n")
    }
    
    return sb.String()
}

func needsSearch(query string) bool {
    query = strings.ToLower(query)

    searchIndicators := []string{
        "последние", "новости", "сегодня", "сейчас", "актуальные",
        "цена", "стоимость", "сколько стоит", "прайс", "рынок",
        "2025", "2026", "этом году", "текущие", "свежие",
        "тренды", "тенденции", "обзор", "аналитика",
    }

    for _, word := range searchIndicators {
        if strings.Contains(query, word) {
            return true
        }
    }

    return false
}

type YandexGPTRequest struct {
    ModelUri          string `json:"modelUri"`
    CompletionOptions struct {
        Stream      bool    `json:"stream"`
        Temperature float64 `json:"temperature"`
        MaxTokens   int     `json:"maxTokens"`
    } `json:"completionOptions"`
    Messages []struct {
        Role string `json:"role"`
        Text string `json:"text"`
    } `json:"messages"`
}

type YandexGPTResponse struct {
    Result struct {
        Alternatives []struct {
            Message struct {
                Role string `json:"role"`
                Text string `json:"text"`
            } `json:"message"`
        } `json:"alternatives"`
        Usage struct {
            InputTextTokens  string `json:"inputTextTokens"`
            CompletionTokens string `json:"completionTokens"`
            TotalTokens      string `json:"totalTokens"`
        } `json:"usage"`
        ModelVersion string `json:"modelVersion"`
    } `json:"result"`
}

