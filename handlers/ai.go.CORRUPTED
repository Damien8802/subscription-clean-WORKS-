func getGreeting() string {
    hour := time.Now().Hour()
    switch {
    case hour >= 5 && hour < 12:
        return "Доброе утро"
    case hour >= 12 && hour < 17:
        return "Добрый день"
    case hour >= 17 && hour < 24:
        return "Добрый вечер"
    default:
        return "Доброй ночи"
    }
}

func calculateProjectCost(serviceType, goal, features, integration, design, audience string) float64 {
    serviceType = strings.ToLower(serviceType)
    goal = strings.ToLower(goal)
    design = strings.ToLower(design)
    integration = strings.ToLower(integration)
    features = strings.ToLower(features)

    log.Printf("[AI] РАСЧЕТ: услуга=%s, цель=%s", serviceType, goal)

    baseCost := 35000.0

    // Определяем тип проекта
    if strings.Contains(serviceType, "бот") || strings.Contains(serviceType, "telegram") {
        if strings.Contains(goal, "магазин") || strings.Contains(goal, "каталог") {
            baseCost = 50000
        } else if strings.Contains(goal, "рассылк") || strings.Contains(features, "рассылк") {
            baseCost = 30000
        } else {
            baseCost = 25000
        }
        log.Printf("[AI] Базовая стоимость бота: %.0f", baseCost)
    } else if strings.Contains(serviceType, "crm") {
        baseCost = 40000
        log.Printf("[AI] Базовая стоимость CRM: %.0f", baseCost)
    } else if strings.Contains(serviceType, "магазин") || strings.Contains(serviceType, "сайт") {
        baseCost = 45000
        log.Printf("[AI] Базовая стоимость магазина: %.0f", baseCost)
    }

    // Добавляем за дизайн
    if strings.Contains(design, "да") || strings.Contains(design, "хочу") || strings.Contains(design, "нужен") {
        baseCost += 10000
        log.Printf("[AI] +10000 за дизайн")
    }

    // Добавляем за интеграции
    if strings.Contains(integration, "да") || strings.Contains(integration, "нужн") || strings.Contains(integration, "интеграция") {
        baseCost += 15000
        log.Printf("[AI] +15000 за интеграции")
    }

    // Добавляем за сложные функции
    if strings.Contains(features, "платеж") || strings.Contains(features, "оплат") || 
       strings.Contains(goal, "платеж") || strings.Contains(goal, "оплат") {
        baseCost += 20000
        log.Printf("[AI] +20000 за платежи")
    }

    if strings.Contains(features, "админ") || strings.Contains(features, "панель") ||
       strings.Contains(goal, "админ") || strings.Contains(goal, "панель") {
        baseCost += 15000
        log.Printf("[AI] +15000 за админ панель")
    }

    if strings.Contains(features, "mini app") || strings.Contains(goal, "mini app") {
        baseCost += 30000
        log.Printf("[AI] +30000 за Mini App")
    }

    log.Printf("[AI] ИТОГО: %.0f ₽", baseCost)
    return baseCost
}

func saveServiceRequest(req ServiceRequest) error {
    log.Printf("[DB] Сохранение заявки: %+v", req)
    return nil
}

func sendClientNotification(state *DialogState) {
    minMinutes := 5
    maxMinutes := 15
    
    rand.Seed(time.Now().UnixNano())
    minutes := minMinutes + rand.Intn(maxMinutes-minMinutes+1)
    
    message := fmt.Sprintf("✅ **Отлично! Ваша заявка принята!**\n\n📋 **Детали заявки:**\n• Услуга: %s\n• Цель: %s\n• Срок: %s\n• Стоимость: %.0f ₽\n\n🕐 Наш специалист свяжется с вами в ближайшие **%d минут**.\n\nСпасибо за обращение! 🙏",
        state.ServiceType, state.Goal, state.Timeline, state.EstimatedCost, minutes)

    if state.ContactType == "telegram" && state.Contact != "" {
        botToken := os.Getenv("TELEGRAM_BOT_TOKEN")
        if botToken == "" {
            return
        }
        bot, err := tgbotapi.NewBotAPI(botToken)
        if err != nil {
            log.Printf("[ERROR] Ошибка создания бота: %v", err)
            return
        }
        var chatIDInt int64
        fmt.Sscanf(state.Contact, "%d", &chatIDInt)
        msg := tgbotapi.NewMessage(chatIDInt, message)
        msg.ParseMode = "Markdown"
        _, err = bot.Send(msg)
        if err != nil {
            log.Printf("[ERROR] Ошибка отправки уведомления клиенту: %v", err)
        } else {
            log.Printf("[INFO] Уведомление клиенту отправлено (связь через %d мин)", minutes)
        }
    } else if state.ContactType == "phone" {
        log.Printf("📱 SMS на %s: %s (связь через %d мин)", state.Contact, message, minutes)
    }
}

func boolToYesNo(b bool) string {
    if b {
        return "Да"
    }
    return "Нет"
}

func notifyAdminViaTelegram(req ServiceRequest) {
    botToken := os.Getenv("TELEGRAM_BOT_TOKEN")
    if botToken == "" {
        log.Printf("[ERROR] TELEGRAM_BOT_TOKEN не настроен")
        return
    }

    bot, err := tgbotapi.NewBotAPI(botToken)
    if err != nil {
        log.Printf("[ERROR] Ошибка создания бота: %v", err)
        return
    }

    adminChatIDStr := os.Getenv("ADMIN_CHAT_ID")
    if adminChatIDStr == "" {
        log.Printf("[ERROR] ADMIN_CHAT_ID не настроен")
        return
    }

    var adminChatID int64
    fmt.Sscanf(adminChatIDStr, "%d", &adminChatID)

    messengers := "Нет"
    messengerList := []string{}
    if req.HasWhatsApp {
        messengerList = append(messengerList, "WhatsApp")
    }
    if req.HasTelegram {
        messengerList = append(messengerList, "Telegram")
    }
    if req.HasMessenger {
        messengerList = append(messengerList, "Messenger")
    }
    if len(messengerList) > 0 {
        messengers = strings.Join(messengerList, " + ")
    }

    description := req.Description
    if description == "" {
        description = fmt.Sprintf("Услуга: %s | Цель: %s", req.ServiceType, req.Goal)
    }

    telegramNick := req.TelegramNick
    if telegramNick == "" && req.ContactType == "telegram" {
        telegramNick = strings.TrimPrefix(req.Contact, "@")
    }

    message := fmt.Sprintf("🔔 **НОВАЯ ЗАЯВКА!**\n\n👤 **Имя:** %s\n📞 **Контакт:** %s (%s)\n📱 **Telegram ник:** @%s\n💬 **Мессенджеры:** %s\n\n📝 **Услуга:** %s\n🎯 **Цель:** %s\n⚙️ **Функции:** %s\n🎨 **Дизайн:** %s\n🔌 **Интеграции:** %s\n👥 **Аудитория:** %s\n⏱️ **Срок:** %s\n💰 **Бюджет:** %s ₽\n\n💵 **Стоимость:** %.0f ₽\n✅ **Цена устроила:** %s\n➕ **Техподдержка:** %s\n💳 **ИТОГО:** %.0f ₽\n⚡️ **Предоплата:** %.0f ₽\n\n🕐 **Время:** %s",
        req.Name,
        req.Contact,
        req.ContactType,
        telegramNick,
        messengers,
        req.ServiceType,
        req.Goal,
        req.Features,
        req.Design,
        req.Integration,
        req.TargetAudience,
        req.Timeline,
        req.Budget,
        req.ProjectCost,
        boolToYesNo(req.AgreedToPrice),
        boolToYesNo(req.AgreedToExtra),
        req.TotalAmount,
        req.TotalAmount/2,
        req.CreatedAt.Format("15:04 02.01.2006"))

    msg := tgbotapi.NewMessage(adminChatID, message)
    msg.ParseMode = "Markdown"

    _, err = bot.Send(msg)
    if err != nil {
        log.Printf("[ERROR] Ошибка отправки админу (Markdown): %v", err)
        msg.ParseMode = ""
        _, err = bot.Send(msg)
        if err != nil {
            log.Printf("[ERROR] Ошибка отправки админу (plain): %v", err)
        }
    } else {
        log.Printf("[INFO] Уведомление админу отправлено")
    }
}

func forceSendServiceRequest(state *DialogState, sessionID string) {
    if state.ForceRequestSent {
        return
    }

    totalAmount := state.EstimatedCost
    if state.AgreedToExtra {
        totalAmount += 5000
    }

    extraService := "нет"
    if state.AgreedToExtra {
        extraService = "Да (+5000 ₽/мес)"
    }

    description := fmt.Sprintf("Услуга: %s | Цель: %s | Функции: %s | Дизайн: %s | Интеграции: %s | Аудитория: %s",
        state.ServiceType, state.Goal, state.Features, state.Design, state.Integration, state.TargetAudience)

    telegramNick := state.TelegramNick
    if telegramNick == "" && state.ContactType == "telegram" {
        telegramNick = strings.TrimPrefix(state.Contact, "@")
    }

    serviceReq := ServiceRequest{
        Name:           state.UserName,
        Contact:        state.Contact,
        ContactType:    state.ContactType,
        Description:    description,
        ServiceType:    state.ServiceType,
        Goal:           state.Goal,
        Features:       state.Features,
        Design:         state.Design,
        Integration:    state.Integration,
        TargetAudience: state.TargetAudience,
        Timeline:       state.Timeline,
        Budget:         fmt.Sprintf("%.0f", totalAmount),
        Status:         "new",
        CreatedAt:      time.Now(),
        HasWhatsApp:    state.HasWhatsApp,
        HasTelegram:    state.HasTelegram,
        HasMessenger:   state.HasMessenger,
        TotalAmount:    totalAmount,
        ExtraService:   extraService,
        ProjectCost:    state.EstimatedCost,
        AgreedToPrice:  state.AgreedToPrice,
        AgreedToExtra:  state.AgreedToExtra,
        TelegramNick:   telegramNick,
    }

    err := saveServiceRequest(serviceReq)
    if err != nil {
        log.Printf("[ERROR] Ошибка сохранения заявки: %v", err)
    }

    notifyAdminViaTelegram(serviceReq)

    // Отправляем уведомление клиенту и добавляем финальное сообщение
    if !state.NotificationSent {
        sendClientNotification(state)
        state.NotificationSent = true
        
        // Добавляем финальное пожелание в историю
        state.Messages = append(state.Messages, "assistant: ✅ Спасибо за обращение! Всего хорошего! 👋")
    }

    state.ForceRequestSent = true
    
    dialogMutex.Lock()
 func extractDataFromMessage(message string, state *DialogState) {   delete(dialogStates, sessionID)
    dialogMutex.Unlock()
    
    log.Printf("[INFO] Заявка отправлена для сессии %s", sessionID)
}


    originalMessage := message
    message = strings.ToLower(strings.TrimSpace(message))
    if message == "" {
        return
    }

    log.Printf("Шаг %d: %s", state.Step, originalMessage)

    // Проверка на просьбу связаться с разработчиком
    if strings.Contains(message, "свяжи") || strings.Contains(message, "разработчик") || 
       strings.Contains(message, "специалист") || strings.Contains(message, "помощь специалиста") {
        
        log.Printf("👨‍💻 Запрос на связь с разработчиком")
        if state.ServiceType == "" {
            state.ServiceType = "Консультация с разработчиком"
        }
        if state.Goal == "" {
            state.Goal = "Требуется помощь специалиста"
        }
        state.Step = 10
        return
            if state.Features == "" && !isCommonWord(message) && len(originalMessage) > 2 {
                state.Features = originalMessage
                state.Step = 4
                log.Printf("⚙️ Функции: %s", state.Features)
                return
            }
        case 4:
            if state.Design == "" {
                phoneDigits := 0
                for _, ch := range originalMessage {
                    if ch >= '0' && ch <= '9' {
                        phoneDigits++
                    }
                }
                isPhone := phoneDigits >= 10
                
                if isPhone {
                    state.ContactType = "phone"
                    state.Contact = strings.ReplaceAll(originalMessage, " ", "")
                    state.Step = 8
                    log.Printf("📞 Телефон: %s", state.Contact)
                    return
                }
                
                if strings.Contains(message, "да") || strings.Contains(message, "хочу") || 
                   strings.Contains(message, "нужен") {
                    state.Design = "Да, нужен дизайн"
                    state.Step = 5
                    log.Printf("🎨 Нужен дизайн")
                } else if strings.Contains(message, "нет") || strings.Contains(message, "не") {
                    state.Design = "Дизайн не требуется"
                    state.Step = 5
                    log.Printf("➡️ Дизайн не нужен")
                } else {
                    state.Design = originalMessage
                    state.Step = 5
                    log.Printf("🎨 Пожелания: %s", state.Design)
                }
                return
            }
        case 5:
            if state.Integration == "" && !isCommonWord(message) && len(originalMessage) > 2 {
                state.Integration = originalMessage
                state.Step = 6
                log.Printf("🔌 Интеграции: %s", state.Integration)
                return
            }
        case 6:
            if state.TargetAudience == "" && !isCommonWord(message) && len(originalMessage) > 2 {
                state.TargetAudience = originalMessage
                state.Step = 7
                log.Printf("👥 Аудитория: %s", state.TargetAudience)
                return
            }
        case 7:
            if state.Timeline == "" && !isCommonWord(message) && len(originalMessage) > 2 {
                state.Timeline = originalMessage
                state.EstimatedCost = calculateProjectCost(
                    state.ServiceType,
                    state.Goal,
                    state.Features,
                    state.Integration,
                    state.Design,
                    state.TargetAudience,
                )
                state.Step = 8
                state.PriceCalculated = true
                log.Printf("💰 Стоимость: %.0f ₽", state.EstimatedCost)
                return
            }
        case 8:
            if strings.Contains(message, "да") || strings.Contains(message, "согласен") || 
               strings.Contains(message, "ок") || strings.Contains(message, "хорошо") {
                state.AgreedToPrice = true
                state.Step = 9
                log.Printf("✅ Согласие на цену")
                return
            } else if strings.Contains(message, "нет") || strings.Contains(message, "дорого") {
                state.AgreedToPrice = false
                state.Step = 9
                log.Printf("⚠️ Отказ от цены")
                return
            }
        case 9:
            if strings.Contains(message, "да") || strings.Contains(message, "хочу") || 
               strings.Contains(message, "добавь") {
                state.AgreedToExtra = true
                state.AskedExtraService = true
                state.Step = 10
                log.Printf("✅ Согласие на техподдержку")
                return
            } else if strings.Contains(message, "нет") || strings.Contains(message, "не") {
                state.AgreedToExtra = false
                state.AskedExtraService = true
                state.Step = 10
                log.Printf("⚠️ Отказ от техподдержки")
                return
            }
        case 10:
            phoneDigits := 0
            phoneNumber := ""
            for _, ch := range originalMessage {
                if ch >= '0' && ch <= '9' {
                    phoneDigits++
                    phoneNumber += string(ch)
                }
            }
            isPhone := phoneDigits >= 10
            
            if isPhone {
                state.ContactType = "phone"
                state.Contact = phoneNumber
                state.Step = 11
                log.Printf("📞 Телефон: %s", state.Contact)
                return
            }
            if strings.HasPrefix(originalMessage, "@") {
                state.ContactType = "telegram"
                state.Contact = originalMessage
                state.TelegramNick = strings.TrimPrefix(originalMessage, "@")
                state.HasTelegram = true
                state.Step = 11
                log.Printf("📱 Telegram: %s", state.Contact)
                return
            }
        case 11:
            if strings.Contains(message, "whatsapp") || strings.Contains(message, "ватсап") {
                state.HasWhatsApp = true
            }
            if strings.Contains(message, "telegram") || strings.Contains(message, "телеграм") {
                state.HasTelegram = true
            }
            state.AskedMessengers = true
            state.Step = 12
            log.Printf("📱 Мессенджеры: WhatsApp=%v, Telegram=%v", state.HasWhatsApp, state.HasTelegram)
            return
        }
    }
}

func isCommonWord(word string) bool {
    commonWords := map[string]bool{
        "привет": true, "здравствуйте": true, "здравствуй": true, 
        "добрый": true, "добрай": true, "доброе": true, "доброй": true,
        "день": true, "вечер": true, "утро": true, "ночь": true, 
        "помогите": true, "помощь": true, "вопрос": true, 
        "есть": true, "можно": true, "спросить": true,
        "хочу": true, "надо": true, "нужно": true, "нада": true,
        "спасибо": true, "пожалуйста": true, "пож": true,
        "услуг": true, "услуга": true, "услуги": true, "заказать": true,
        "сделать": true, "создать": true, "разработать": true,
        "да": true, "нет": true, "ок": true, "окей": true, "хорошо": true,
        "нужна": true, "нужен": true, "нужно": true,
    }
    return commonWords[word]
}

// ДОБАВЛЯЕМ ЭТУ ФУНКЦИЮ ЗДЕСЬ!
func isGreeting(word string) bool {
    greetings := map[string]bool{
        "привет": true, "здравствуйте": true, "здравствуй": true,
        "доброе": true, "добрый": true, "добрай": true, "доброй": true,
        "утро": true, "день": true, "вечер": true, "ночь": true,
        "хай": true, "хелло": true, "hello": true, "hi": true,
    }
    return greetings[word]
}

func AIAskHandler(c *gin.Context) {
    var req AskRequest
    if err := c.ShouldBindJSON(&req); err != nil {
        c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
        return
    }
    // ... остальной код AIAskHandler
    if req.SessionID == "" {
        req.SessionID = fmt.Sprintf("session_%d", time.Now().UnixNano())
    }

    dialogMutex.Lock()
    state, exists := dialogStates[req.SessionID]
    if !exists {
        state = &DialogState{
            Step:           0,
            DialogType:     "service",
            Messages:       []string{},
            LastUpdated:    time.Now(),
            GreetingShown:  false,
        }
        dialogStates[req.SessionID] = state
    }
    state.LastUpdated = time.Now()
    dialogMutex.Unlock()

    // Обрабатываем сообщение
    if req.Question != "" {
        extractDataFromMessage(req.Question, state)
        state.Messages = append(state.Messages, "user: "+req.Question)
    }

    conversationHistory := ""
    for i, msg := range state.Messages {
        conversationHistory += fmt.Sprintf("%d. %s\n", i+1, msg)
    }

      greeting := getGreeting()

    firstMessage := ""
    if !state.GreetingShown {
        if state.UserName == "" {
            firstMessage = fmt.Sprintf("%s! Как к вам обращаться?", greeting)
        } else {
            firstMessage = fmt.Sprintf("%s, %s! Чем могу помочь?", greeting, state.UserName)
        }
        state.GreetingShown = true
    }
    // Краткий опрос структуры
    if state.Step == 1 && state.ServiceType == "" {
        // Уже спросили имя, теперь спрашиваем услугу
        // Это обработается в системном промпте
    }
    // Поиск в интернете
    searchResults := ""

    if strings.Contains(req.Question, "сколько стоит") ||
        strings.Contains(req.Question, "цена") ||
        strings.Contains(req.Question, "стоимость") ||
        strings.Contains(req.Question, "прайс") {

        log.Println("[AI] Поиск цен...")
        priceInfo, _, err := searchAverageBotPrice(req.Question, state.ServiceType)
        if err != nil {
            log.Printf("[ERROR] Ошибка поиска цен: %v", err)
        }
        if priceInfo != "" {
            searchResults = "\n\n" + priceInfo
        }
    } else if needsSearch(req.Question) {
        log.Println("[AI] Поиск в интернете...")
        results, err := searchWithYandex(req.Question)
        if err != nil {
            log.Printf("[ERROR] Ошибка поиска: %v", err)
        }
        if results != "" {
            searchResults = "\n\n" + results
        }
    }

    // ПОЛУЧАЕМ API КЛЮЧИ ЯНДЕКСА
    apiKey := os.Getenv("YANDEX_API_KEY")
    folderID := os.Getenv("YANDEX_FOLDER_ID")
    if apiKey == "" || folderID == "" {
        c.JSON(http.StatusInternalServerError, gin.H{"error": "API ключи не настроены"})
        return
    }

       // Системный промпт
    systemPrompt := fmt.Sprintf(`%s

%s
%s

ТЕКУЩИЙ ДИАЛОГ:
Имя: %s
Шаг сбора заявки: %d

ТЫ - УМНЫЙ AI-АССИСТЕНТ, КОТОРЫЙ ОТВЕЧАЕТ КАК ЭКСПЕРТ:

📌 **ОСНОВНЫЕ ПРАВИЛА:**
1. Здороваешься ТОЛЬКО ПЕРВЫЙ РАЗ по времени суток. Больше НИКОГДА не здороваешься.
2. Отвечаешь КРАТКО и ПО ДЕЛУ, без воды.
3. Задаешь ТОЛЬКО ОДИН вопрос за раз.

🤖 **ПОСЛЕДОВАТЕЛЬНОСТЬ ОПРОСА:**
1. Спросить имя (если не знаешь)
2. Спросить: "Какая услуга нужна?"
3. Спросить: "Какие функции должны быть?"
4. Спросить: "Есть пожелания по дизайну?"
5. Спросить: "Сроки?"
6. Назвать цену (из интернета)
7. Спросить: "Вас устраивает цена?"
8. Спросить про техподдержку
9. Попросить контакт
10. Отправить заявку

💡 **ПРИМЕРЫ КРАТКИХ ОТВЕТОВ:**
- "Какая услуга нужна?"
- "Какие функции?"
- "Дизайн нужен?"
- "Сроки?"
- "Цена: 35000 ₽. Устраивает?"
- "Техподдержка за 5000/мес?"
- "Ваш телефон или Telegram?"

ТЕКУЩИЙ ВОПРОС: %s

История диалога:
%s`,
        firstMessage, servicesList, searchResults,
        state.UserName, state.Step,
        req.Question, conversationHistory)
    requestBody := YandexGPTRequest{
        ModelUri: fmt.Sprintf("gpt://%s/yandexgpt-lite", folderID),
        CompletionOptions: struct {
            Stream      bool    `json:"stream"`
            Temperature float64 `json:"temperature"`
            MaxTokens   int     `json:"maxTokens"`
        }{
            Stream:      false,
            Temperature: 0.8,
            MaxTokens:   1500,
        },
        Messages: []struct {
            Role string `json:"role"`
            Text string `json:"text"`
        }{
            {Role: "system", Text: systemPrompt},
            {Role: "user", Text: req.Question},
        },
    }

    jsonBody, err := json.Marshal(requestBody)
    if err != nil {
        log.Printf("[ERROR] Ошибка маршалинга запроса: %v", err)
        c.JSON(http.StatusInternalServerError, gin.H{"error": "Ошибка формирования запроса"})
        return
    }

    client := &http.Client{Timeout: 30 * time.Second}
    yandexReq, err := http.NewRequest("POST", "https://llm.api.cloud.yandex.net/foundationModels/v1/completion", bytes.NewBuffer(jsonBody))
    if err != nil {
        log.Printf("[ERROR] Ошибка создания запроса: %v", err)
        c.JSON(http.StatusInternalServerError, gin.H{"error": "Ошибка создания запроса"})
        return
    }

    yandexReq.Header.Set("Content-Type", "application/json")
    yandexReq.Header.Set("Authorization", "Api-Key "+apiKey)

    resp, err := client.Do(yandexReq)
    if err != nil {
        log.Printf("[ERROR] Ошибка YandexGPT: %v", err)
        c.JSON(http.StatusInternalServerError, gin.H{"error": "Ошибка YandexGPT"})
        return
    }
    defer resp.Body.Close()

    body, err := io.ReadAll(resp.Body)
    if err != nil {
        log.Printf("[ERROR] Ошибка чтения ответа: %v", err)
        c.JSON(http.StatusInternalServerError, gin.H{"error": "Ошибка чтения ответа"})
        return
    }

    var gptResp YandexGPTResponse
    if err := json.Unmarshal(body, &gptResp); err != nil {
        log.Printf("[ERROR] Ошибка парсинга ответа: %v, тело: %s", err, string(body))
        c.JSON(http.StatusInternalServerError, gin.H{"error": "Ошибка парсинга ответа"})
        return
    }

      finalAnswer := ""
    if len(gptResp.Result.Alternatives) > 0 {
        finalAnswer = gptResp.Result.Alternatives[0].Message.Text
        state.Messages = append(state.Messages, "assistant: "+finalAnswer)
    }

    // Проверяем, нужно ли отправить заявку (для разработчика или обычной заявки)
    if state.Contact != "" && !state.ForceRequestSent {
        if state.UserName == "" {
            state.UserName = "Клиент"
        }
        if state.ServiceType == "" {
            state.ServiceType = "Консультация"
        }
        if state.Goal == "" {
            state.Goal = "Связь с разработчиком"
        }
        if state.Timeline == "" {
            state.Timeline = "срочно"
        }
        
        log.Printf("📨 Отправляем заявку в Telegram: %s %s", state.ServiceType, state.Contact)
        forceSendServiceRequest(state, req.SessionID)
    }

    c.JSON(http.StatusOK, gin.H{
        "answer":     finalAnswer,
        "type":       "service",
        "session_id": req.SessionID,
        "delay":      2,
    })
}
